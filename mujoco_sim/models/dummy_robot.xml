<mujoco model="dummy_v2">
  <!-- MuJoCo 模型文件 for Dummy V2 机械臂 -->
  <!-- 基于任同学/木子晓汶版本的参数 -->

  <compiler angle="degree" meshdir="../../../../4.Model/木子晓汶版本3D模型/" autolimits="true"/>

  <option timestep="0.005" iterations="50" tolerance="1e-10" solver="Newton" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint armature="0.01" damping="2" limited="true"/>
    <geom contype="0" conaffinity="0" group="1" type="mesh" rgba="0.8 0.8 0.8 1"/>
    <position ctrllimited="true" ctrlrange="-100 100"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.1"/>
    <material name="joint" rgba="0.2 0.6 0.8 1"/>
    <material name="link" rgba="0.7 0.7 0.7 1"/>
    <material name="base" rgba="0.3 0.3 0.3 1"/>
    
    <!-- 网格文件 -->
    <mesh name="base_mesh" file="base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="joint1_mesh" file="joint1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="joint23_mesh" file="joint23.stl" scale="0.001 0.001 0.001"/>
    <mesh name="joint4_mesh" file="joint4.stl" scale="0.001 0.001 0.001"/>
    <mesh name="joint5_mesh" file="joint5.stl" scale="0.001 0.001 0.001"/>
    <mesh name="joint6_mesh" file="joint6.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <!-- 地面 -->
    <geom name="floor" size="0 0 0.05" type="plane" material="grid"/>
    <light name="spotlight" mode="targetbodycom" target="base" pos="0 -1 2"/>
    
    <!-- 机械臂基座 -->
    <body name="base" pos="0 0 0">
      <geom name="base_geom" mesh="base_mesh" material="base"/>
      
      <!-- Joint 1: 底座旋转 -->
      <body name="link1" pos="0 0 0.109">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-170 170" damping="1"/>
        <geom name="joint1_geom" mesh="joint1_mesh" material="joint"/>
        
        <!-- Joint 2: 肩部 -->
        <body name="link2" pos="0 0 0.035">
          <joint name="joint2" type="hinge" axis="0 1 0" range="-75 0" damping="1"/>
          <geom name="joint2_geom" mesh="joint23_mesh" material="link"/>
          
          <!-- Joint 3: 肘部 -->
          <body name="link3" pos="0 0 0.146">
            <joint name="joint3" type="hinge" axis="0 1 0" range="35 180" damping="1"/>
            <geom name="joint3_geom" mesh="joint23_mesh" material="link"/>
            
            <!-- Joint 4: 小臂旋转 -->
            <body name="link4" pos="0 0 0.115">
              <joint name="joint4" type="hinge" axis="0 0 1" range="-170 170" damping="0.5"/>
              <geom name="joint4_geom" mesh="joint4_mesh" material="joint"/>
              
              <!-- Joint 5: 腕部 -->
              <body name="link5" pos="0 0 0.052">
                <joint name="joint5" type="hinge" axis="0 1 0" range="-120 120" damping="0.5"/>
                <geom name="joint5_geom" mesh="joint5_mesh" material="link"/>
                
                <!-- Joint 6: 末端旋转 -->
                <body name="link6" pos="0 0 0.072">
                  <joint name="joint6" type="hinge" axis="0 0 1" range="-720 720" damping="0.5"/>
                  <geom name="joint6_geom" mesh="joint6_mesh" material="joint"/>
                  
                  <!-- 末端执行器标记 -->
                  <site name="end_effector" pos="0 0 0.02" size="0.01" rgba="1 0 0 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="joint1_ctrl" joint="joint1" kp="1000" kv="100" ctrlrange="-170 170"/>
    <position name="joint2_ctrl" joint="joint2" kp="1000" kv="100" ctrlrange="-75 0"/>
    <position name="joint3_ctrl" joint="joint3" kp="1000" kv="100" ctrlrange="35 180"/>
    <position name="joint4_ctrl" joint="joint4" kp="800" kv="80" ctrlrange="-170 170"/>
    <position name="joint5_ctrl" joint="joint5" kp="800" kv="80" ctrlrange="-120 120"/>
    <position name="joint6_ctrl" joint="joint6" kp="500" kv="50" ctrlrange="-720 720"/>
  </actuator>

  <sensor>
    <!-- 关节位置传感器 -->
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="joint6_pos" joint="joint6"/>
    
    <!-- 末端位置传感器 -->
    <framepos name="end_effector_pos" objtype="site" objname="end_effector"/>
    <framequat name="end_effector_quat" objtype="site" objname="end_effector"/>
  </sensor>

</mujoco>
